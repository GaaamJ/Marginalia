          useStatGate: 0
          gateStat: 0
          minStatValue: 0
          maxStatValue: 4
        - text: "\uB2F9\uC2E0\uC740 \uBB38\uACE0\uB9AC\uB97C \uC7A1\uC2B5\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC740
