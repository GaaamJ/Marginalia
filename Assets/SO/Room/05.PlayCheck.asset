      onSuccess:
        narration:
        - text: "\uB2F9\uC2E0\uC740 \uADF8\uAC83\uB4E4\uC744 \uAD00\uCC30\uD558\uACE0
            \uC774\uD574\uD569\uB2C8\uB2E4.\n\uB2F9\uC2E0\uC740 \uADF8\uAC83\uB4E4\uCC98\uB7FC
