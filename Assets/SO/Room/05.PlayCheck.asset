          maxStatValue: 4
        - text: "\uB2F9\uC2E0\uC758 \uC5F0\uADF9\uC744 \uADF8\uAC83\uB4E4\uC774 \uB208\uCE58\uCC58\uC2B5\uB2C8\uB2E4.\n\uB2F9\uC2E0\uC5D0\uAC8C
            \uADF8\uAC83\uB4E4\uC774 \uB2EC\uB824\uB4ED\uB2C8\uB2E4."
          channel: 1
          pauseAfter: 1.5
          shakeIntensity: 0.8
          shakeFrequency: 8
          appendMode: 1
          useStatGate: 0
          gateStat: 0
          minStatValue: 0
          maxStatValue: 4
        - text: "\uB2F9\uC2E0\uC758 \uD314\uC5D0 \uC2E4\uC774 \uBB36\uC774\uACE0
            \uC5BC\uAD74\uC5D0 \uAC00\uBA74\uC774 \uC50C\uC6CC\uC9D1\uB2C8\uB2E4."
