    isRepeatable: 0
    requirementFailNarration: []
    onEnter:
    - text: "\uD589\uB3D9: \uC0AC\uB78C \uC544\uB2CC \uAC83\uB4E4\uC744 \uAD00\uCC30\uD558\uC138\uC694.\r\n\uC0AC\uACE0:
        \uC0AC\uB78C \uC544\uB2CC \uAC83\uB4E4\uC758 \uD589\uB3D9\uC744 \uC774\uD574\uD558\uC138\uC694.\r\n\uD589\uB3D9:
        \uADF8\uAC83\uB4E4\uCC98\uB7FC \uD589\uB3D9\uD558\uC138\uC694."
      channel: 2
      pauseAfter: 1.5
      shakeIntensity: 0.8
      shakeFrequency: 8
