        channel: 1
        pauseAfter: 1.5
        shakeIntensity: 0.8
        shakeFrequency: 8
        appendMode: 1
        useStatGate: 0
        gateStat: 0
        minStatValue: 0
        maxStatValue: 4
      onAfterCheck:
      - text: "\uB2F9\uC2E0\uC740 \uADF8\uAC83\uB4E4\uC774 \uD558\uB294 \uAC83\uC744
          \uC774\uD574\uD558\uB824 \uB178\uB825\uD569\uB2C8\uB2E4.\r\n\uB2F9\uC2E0\uC740
          \uADF8\uAC83\uB4E4\uC774 \uD558\uB294 \uAC83\uC744 \uB530\uB77C\uD574\uBD05\uB2C8\uB2E4."
        channel: 1
        pauseAfter: 1.5
        shakeIntensity: 0.8
        shakeFrequency: 8
