          gateStat: 0
          minStatValue: 0
          maxStatValue: 4
        - text: "\uB2F9\uC2E0\uC740 \uBB38 \uC55E\uC5D0 \uC12D\uB2C8\uB2E4.\n\uB2F9\uC2E0\uC758
