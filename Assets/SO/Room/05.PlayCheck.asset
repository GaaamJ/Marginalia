      onFailure:
        narration:
        - text: "\uB2F9\uC2E0\uC740 \uC544\uBB34\uB9AC \uBAB8\uC744 \uB4A4\uD2C0\uC5B4\uB3C4
            \uADF8\uB4E4\uCC98\uB7FC \uD589\uB3D9\uD558\uC9C0 \uBABB\uD588\uC2B5\uB2C8\uB2E4."
