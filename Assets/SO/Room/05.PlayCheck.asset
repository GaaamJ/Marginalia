      useStatGate: 0
      gateStat: 0
      minStatValue: 0
      maxStatValue: 4
    - text: "\uC0AC\uACE0: \uB2F9\uC2E0\uC744 \uC78A\uC9C0 \uB9C8\uC138\uC694."
      channel: 2
      pauseAfter: 1.5
      shakeIntensity: 0.8
      shakeFrequency: 8
      appendMode: 1
      useStatGate: 0
      gateStat: 0
      minStatValue: 0
      maxStatValue: 4
    exitCondition: 1
    checkData:
      onBeforeCheck:
      - text: "\uB2F9\uC2E0\uC740 \uC6C3\uB294 \uAC00\uBA74\uC744 \uC4F4 \uC5EC\uC790\uB97C
